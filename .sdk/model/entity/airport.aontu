                orig: "ids"
                reqd: false
                type: "`$STRING`"
              }
            ]
          }
          method: "GET"
          orig: "/api/data/airport"
          parts: [
            "api"
            "data"
            "airport"
          ]
          select: {
            exist: [
              "bbox"
              "format"
              "ids"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }



}
